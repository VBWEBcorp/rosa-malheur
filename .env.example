# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/template-ecommerce

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3004

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mondial Relay (livraison point relais)
# Code Client (8 caractères) — utilisé par le widget de carte côté client.
# Aussi configurable via l'admin → Réglages → Intégrations.
NEXT_PUBLIC_MONDIAL_RELAY_BRAND=CC23RXDD
# Clé privée — pour l'API d'expédition côté serveur uniquement (génération d'étiquettes).
MONDIAL_RELAY_PRIVATE_KEY=wcUB9vw6
# Code Marque (2 chiffres) — pour l'API d'expédition côté serveur.
MONDIAL_RELAY_BRAND_CODE=41

# Resend (envoi d'emails transactionnels)
# Récupérer la clé sur resend.com/api-keys
RESEND_API_KEY=re_xxx
# Adresse d'expéditeur. onboarding@resend.dev fonctionne sans vérification DNS (100 mails/jour max).
# Pour utiliser un domaine personnalisé, vérifier sur resend.com/domains.
RESEND_FROM_EMAIL=Ma Boutique <onboarding@resend.dev>

# Cloudflare R2 (stockage d'images uploadées via l'admin)
CLOUDFLARE_API_TOKEN=cfat_xxx
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=mon-bucket
R2_PREFIX=mon-bucket
# Public URL fournie par Cloudflare après activation de l'accès public sur le bucket.
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Cloudinary (alternative R2, optionnel)
CLOUDINARY_URL=cloudinary://xxx

# Google Indexing API (optionnel — pour indexation instantanee)
# Collez le JSON complet du Service Account Google ici
# GOOGLE_INDEXING_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Adresse qui reçoit les messages des formulaires de contact / devis (via Resend)
CONTACT_TO_EMAIL=contact@example.com

# Compte admin (créé au démarrage en dev, et par `node scripts/setup-admin.mjs` en prod)
# NE METTEZ PAS le vrai mot de passe ici (.env.example est versionné) — utilisez .env.local
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# App
NEXT_PUBLIC_APP_URL=http://localhost:3004
